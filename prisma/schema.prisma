generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model BlogPost {
  id        String   @id @default(cuid())
  title     String
  content   String   @db.Text
  project   String?
  published Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([published])
  @@index([project])
}

model Music {
  id    String @id @default(cuid())
  title String
  artist String
  url   String
  coverUrl String?
  createdAt DateTime @default(now())
}
