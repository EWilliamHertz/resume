generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model BlogPost {
  id        String   @id @default(cuid())
  title     String
  content   String   @db.Text
  project   String?
  published Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([published])
  @@index([project])
}

model Project {
  id          String   @id @default(cuid())
  title       String
  description String   @db.Text
  github      String?
  vercel      String?
  images      String[] // Array of ImgBB URLs
  published   Boolean  @default(false)
  sortOrder   Int      @default(0) // 0 is highest priority
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
model Music {
  id        String   @id @default(cuid())
  title     String
  artist    String
  url       String
  coverUrl  String?
  createdAt DateTime @default(now())
}

model WorkExperience {
  id               String   @id @default(cuid())
  title            String
  company          String
  shortDescription String   @db.Text
  content          String   @db.Text
  images           String[]
  startDate        DateTime
  endDate          DateTime?
  current          Boolean  @default(false)
  published        Boolean  @default(false)
  sortOrder        Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}